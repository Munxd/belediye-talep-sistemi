@model List<BelediyeTalepSistemi.Models.Talep>

@{
    ViewData["Title"] = "Taleplerim";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Taleplerim</h2>
        <a asp-controller="Talep" asp-action="Create" class="btn btn-primary">Yeni Talep Oluştur</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Henüz oluşturulmuş bir talebiniz bulunmamaktadır.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Kategori</th>
                    <th>Müdürlük</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var talep in Model)
                {
                    <tr>
                        <td>@talep.Baslik</td>
                        <td>@talep.Kategori</td>
                        <td>@talep.Mudurluk?.MudurlukAdi</td>
                        <td>@talep.TalepDurumu?.DurumAdi</td>
                        <td>@talep.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-controller="Talep" asp-action="Details" asp-route-id="@talep.Id" class="btn btn-sm btn-info">
                                Detay
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>