@model BelediyeTalepSistemi.Models.Talep

@{
    ViewData["Title"] = "Talep Detayı";
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header">
            <h3>Yönetici Talep Detayı</h3>
        </div>

        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Vatandaş</dt>
                <dd class="col-sm-9">@Model.ApplicationUser?.AdSoyad</dd>

                <dt class="col-sm-3">Başlık</dt>
                <dd class="col-sm-9">@Model.Baslik</dd>

                <dt class="col-sm-3">Açıklama</dt>
                <dd class="col-sm-9">@Model.Aciklama</dd>

                <dt class="col-sm-3">Kategori</dt>
                <dd class="col-sm-9">@Model.Kategori</dd>

                <dt class="col-sm-3">Müdürlük</dt>
                <dd class="col-sm-9">@Model.Mudurluk?.MudurlukAdi</dd>

                <dt class="col-sm-3">Durum</dt>
                <dd class="col-sm-9">@Model.TalepDurumu?.DurumAdi</dd>

                <dt class="col-sm-3">Öncelik</dt>
                <dd class="col-sm-9">@Model.OncelikSeviyesi</dd>

                <dt class="col-sm-3">Açık Adres</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.AcikAdres))
                    {
                        @Model.AcikAdres
                    }
                    else
                    {
                        <span class="text-muted">Adres bilgisi girilmemiş.</span>
                    }
                </dd>

                <dt class="col-sm-3">Konum</dt>
                <dd class="col-sm-9">
                    @if (Model.Enlem != null && Model.Boylam != null)
                    {
                        <span>Enlem: @Model.Enlem</span>
                        <br />
                        <span>Boylam: @Model.Boylam</span>
                    }
                    else
                    {
                        <span class="text-muted">Konum bilgisi bulunmuyor.</span>
                    }
                </dd>

                <dt class="col-sm-3">Oluşturulma Tarihi</dt>
                <dd class="col-sm-9">@Model.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>

            @if (!string.IsNullOrEmpty(Model.FotografYolu))
            {
                <hr />

                <h5>Eklenen Fotoğraf</h5>

                <img src="@Model.FotografYolu"
                     class="img-fluid rounded shadow-sm"
                     style="max-width: 400px;"
                     alt="Talep fotoğrafı" />
            }

            <hr />

            <a asp-controller="Yonetici" asp-action="Index" class="btn btn-secondary">Yönetici Paneline Dön</a>
            <a asp-controller="Yonetici" asp-action="AssignMudurluk" asp-route-id="@Model.Id" class="btn btn-warning">Müdürlük Ata</a>
        </div>
    </div>
</div>