@model List<BelediyeTalepSistemi.Models.Talep>

@{
    ViewData["Title"] = "Personel Paneli";
}

<div class="container mt-5">
    <h2>Personel Paneli</h2>
    <p class="text-muted">Sisteme gelen vatandaş talepleri aşağıda listelenmektedir.</p>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Sistemde henüz oluşturulmuş talep bulunmamaktadır.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Vatandaş</th>
                    <th>Başlık</th>
                    <th>Kategori</th>
                    <th>Müdürlük</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var talep in Model)
                {
                    <tr>
                        <td>@talep.ApplicationUser?.AdSoyad</td>
                        <td>@talep.Baslik</td>
                        <td>@talep.Kategori</td>
                        <td>@talep.Mudurluk?.MudurlukAdi</td>
                        <td>@talep.TalepDurumu?.DurumAdi</td>
                        <td>@talep.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-controller="Personel" asp-action="Details" asp-route-id="@talep.Id" class="btn btn-sm btn-info">
                                Detay
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>