@model BelediyeTalepSistemi.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header text-center">
                <h3>Kayıt Ol</h3>
            </div>
            <div class="card-body">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="AdSoyad" class="form-label"></label>
                        <input asp-for="AdSoyad" class="form-control" />
                        <span asp-validation-for="AdSoyad" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Sifre" class="form-label"></label>
                        <input asp-for="Sifre" type="password" class="form-control" />
                        <span asp-validation-for="Sifre" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SifreTekrar" class="form-label"></label>
                        <input asp-for="SifreTekrar" type="password" class="form-control" />
                        <span asp-validation-for="SifreTekrar" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Kayıt Ol</button>
                </form>

                <div class="text-center mt-3">
                    <a asp-controller="Account" asp-action="Login">Zaten hesabınız var mı? Giriş yapın</a>
                </div>
            </div>
        </div>
    </div>
</div>