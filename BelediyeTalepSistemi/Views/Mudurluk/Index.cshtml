@model List<BelediyeTalepSistemi.Models.Mudurluk>

@{
    ViewData["Title"] = "Müdürlük Yönetimi";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Müdürlük Yönetimi</h2>
        <a asp-controller="Mudurluk" asp-action="Create" class="btn btn-primary">Yeni Müdürlük Ekle</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Müdürlük Adı</th>
                <th>Açıklama</th>
                <th>Bağlı Talep Sayısı</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var mudurluk in Model)
            {
                <tr>
                    <td>@mudurluk.MudurlukAdi</td>
                    <td>@mudurluk.Aciklama</td>
                    <td>@mudurluk.Talepler.Count</td>
                    <td>
                        <a asp-controller="Mudurluk" asp-action="Edit" asp-route-id="@mudurluk.Id" class="btn btn-sm btn-warning">Düzenle</a>
                        <a asp-controller="Mudurluk" asp-action="Delete" asp-route-id="@mudurluk.Id" class="btn btn-sm btn-danger">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>