@model BelediyeTalepSistemi.Models.Mudurluk

@{
    ViewData["Title"] = "Müdürlük Düzenle";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header text-center">
                <h3>Müdürlük Düzenle</h3>
            </div>

            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="MudurlukAdi" class="form-label">Müdürlük Adı</label>
                        <input asp-for="MudurlukAdi" class="form-control" />
                        <span asp-validation-for="MudurlukAdi" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Aciklama" class="form-label">Açıklama</label>
                        <textarea asp-for="Aciklama" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Aciklama" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-warning w-100">Güncelle</button>
                </form>

                <div class="text-center mt-3">
                    <a asp-controller="Mudurluk" asp-action="Index">Müdürlük Listesine Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>